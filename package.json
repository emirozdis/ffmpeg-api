    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.0.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/fluent-ffmpeg": "^2.1.21",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.9",
    "@types/uuid": "^9.0.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
