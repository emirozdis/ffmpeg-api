PORT=3000
API_KEY=replace_with_a_separate_32_byte_random_api_key
TRANSCODER_WEBHOOK_SECRET=replace_with_a_separate_32_byte_random_webhook_secret
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=vlogs
UPLOAD_DIR=./storage/uploads
PROCESSED_DIR=./storage/processed
# Must be on durable storage so jobs survive restarts/deploys.
STATE_DIR=./storage/state
# Comma-separated exact origins. Production has no permissive default.
TRANSCODER_ALLOWED_WEBHOOK_ORIGINS=https://myturn.app
